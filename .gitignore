# AegisGate Lens v0.2 — .gitignore (cherry-picked from v0.1)
#
# Key policy: this repo has ZERO third-party dependencies (npm or otherwise).
# See docs/NO-EXTERNAL-DEPS.md.

# Build outputs
dist/
build/
out/
*.zip
*.crx
*.xpi

# npm artifacts (this repo must NEVER contain any of these; see CONTRIBUTING.md)
package.json
package-lock.json
yarn.lock
pnpm-lock.yaml
node_modules/
.npm
.yarn

# Editor / OS
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swp
*.bak

# Logs / temp
*.log
*.tmp
.env
.env.local
.env.*.local

# Coverage / test artifacts
coverage/
*.lcov
.nyc_output/

# Local-only notes (not part of the published repo)
NOTES.md
TODO-local.md

# ML model files (build artifacts, regenerated from training scripts).
# v0.2 specific: ModernBERT FP32 + INT8 bundles are CI test fixtures
# (needed for security-bundle-verification.test.mjs).
lens-final-dist/vendor/bundles/

# Allow the v0.1.1 bundle as a CI test fixture (used by security-bundle-verification.test.mjs)
!lens_ml_build/aegisgate-lens-v0.1.1.bundle

# Local testing servers and outputs
/tmp/lens_*
.venv/
venv/
*.venv/

# Test scratch space (ephemeral, created and deleted within a single
# test run by test/extension-e2e.test.mjs). Per Standing Rule "NO /tmp/".
.test-scratch/

# Chrome 120 (Chrome-for-Testing 120.0.6046.0) — required for
# real-browser E2E testing because Chrome 130+ silently drops unpacked
# MV3 extensions in this environment (see test/scripts/launch-chrome120.sh
# and plans/AEGISGATE-LENS-V02-DAY-8-2026-06-29.md). Downloaded 2026-06-30
# from https://storage.googleapis.com/chrome-for-testing-public/120.0.6046.0/linux64/
.chrome120/

# Python bytecode (no Python in v0.2, but defensive)
**/__pycache__/
*.pyc
# Backup of legacy v0.1 test runner files (see .v0.1-mirror-backup/README.md)
.v0.1-mirror-backup/

# v0.3.0 additional ignores — model bundles and Firefox port are build
# artifacts, not source code. They are CI test fixtures that get
# downloaded separately.
test/bundles/
test/firefox/
test/eval/*.jsonl
test/eval/*.jsonl.*
test/mock-output/
__pycache__/
*.pyc
